{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "A client account with its targets and managers.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client name" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "contentManagerUid": { "type": "string" },
        "contentManagerName": { "type": "string" },
        "leadGenManagerUid": { "type": "string" },
        "leadGenManagerName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "contentManagerUid", "leadGenManagerUid"]
    },
    "User": {
      "title": "User",
      "description": "System user profile for access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string", "enum": ["content", "leadgen", "both"] },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "assignedClients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "clientId": { "type": "string" },
              "role": { "type": "string", "enum": ["contentManager", "leadGenManager"] }
            }
          }
        },
        "inviteStatus": { "type": "string", "enum": ["active", "disabled"] },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "department", "role"]
    },
    "Invite": {
      "title": "Invite",
      "description": "A pending team invitation.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string", "enum": ["content", "leadgen", "both"] },
        "role": { "type": "string", "const": "member" },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "token": { "type": "string", "description": "Random UUID for verification" }
      },
      "required": ["email", "name", "department", "token"]
    },
    "MetricValue": {
      "type": "object",
      "properties": {
        "value": { "type": ["number", "string", "boolean"] },
        "target": { "type": "number" },
        "status": { "type": "string" },
        "statusOverride": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "WeeklyPerformance": {
      "title": "Weekly Performance",
      "description": "Split metrics data for content and lead gen.",
      "type": "object",
      "properties": {
        "weekOf": { "type": "string", "format": "date" },
        "contentMetrics": {
          "type": "object",
          "additionalProperties": { "$ref": "#/entities/MetricValue" }
        },
        "leadGenMetrics": {
          "type": "object",
          "additionalProperties": { "$ref": "#/entities/MetricValue" }
        },
        "lastUpdatedContent": { "type": "string", "format": "date-time" },
        "lastUpdatedLeadGen": { "type": "string", "format": "date-time" },
        "submittedAtContent": { "type": "string", "format": "date-time" },
        "submittedAtLeadGen": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Client primary data."
    },
    "/weeklyData/{clientId}/{year}/{weekNumber}": {
      "schema": "WeeklyPerformance",
      "description": "Weekly performance snapshots for a client."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and roles."
    },
    "/invites/{inviteId}": {
      "schema": "Invite",
      "description": "Pending member invitations."
    }
  }
}
