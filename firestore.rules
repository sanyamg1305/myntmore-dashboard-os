rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "admin") ||
        (request.auth.token.email == "sanyam@myntmore.com" && isEmailVerified())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collections ---

    // Users collection
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth.uid == uid && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'assignedClients', 'department', 'inviteStatus'])
      );
    }

    // Invites
    match /invites/{inviteId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.email);
      allow write: if isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Client Settings
    match /clientSettings/{clientId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Weekly Data — content and lead gen are separate sub-fields
    match /weeklyData/{clientId}/{year}/{weekNumber} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // High Scores
    match /highScores/{clientId}/metrics/{metricId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // TJ Personal Brand - Nested structure
    match /tjPersonalBrand/{year}/{weekId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Top-level collection for exports
    match /tjPersonalBrand/{docId} {
      allow read: if isSignedIn();
    }

    // Sales Data
    match /salesData/{year}/{weekId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /salesData/{docId} {
      allow read: if isSignedIn();
    }

    // Sales Leads
    match /salesLeads/{leadId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Company-level data
    match /companyData/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
